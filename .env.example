# ============================================================
# ArXiv Daily Researcher - 环境变量配置模板
# ============================================================
# 使用说明:
# 1. 复制此文件并重命名为 .env
# 2. 填入你的 API Key
# 3. 根据需要修改其他配置
# ============================================================

# ============================================================
# LLM API 配置 (必填)
# ============================================================

# 低成本 LLM - 用于快速筛选评分
# 推荐: gpt-4o-mini, deepseek-chat, glm-4-flash
CHEAP_LLM__API_KEY=sk-your-api-key-here
CHEAP_LLM__BASE_URL=https://api.openai.com/v1
CHEAP_LLM__MODEL_NAME=gpt-4o-mini
CHEAP_LLM__TEMPERATURE=0.3

# 高性能 LLM - 用于深度分析
# 推荐: gpt-4o, claude-3-opus, deepseek-chat
SMART_LLM__API_KEY=sk-your-api-key-here
SMART_LLM__BASE_URL=https://api.openai.com/v1
SMART_LLM__MODEL_NAME=gpt-4o
SMART_LLM__TEMPERATURE=0.3

# ============================================================
# 可选配置
# ============================================================

# OpenAlex 邮箱 (进入礼貌池，提高 API 速率限制)
# OPENALEX_EMAIL=your-email@example.com

# OpenAlex API Key (2026年2月后必需)
OPENALEX_API_KEY=your-key-here

# Semantic Scholar API Key (获取 AI 生成的 TLDR，提高速率限制)·
# SEMANTIC_SCHOLAR_API_KEY=your-key-here

# ============================================================
# 使用 DeepSeek 示例
# ============================================================
# CHEAP_LLM__API_KEY=sk-your-deepseek-key
# CHEAP_LLM__BASE_URL=https://api.deepseek.com/v1
# CHEAP_LLM__MODEL_NAME=deepseek-chat
#
# SMART_LLM__API_KEY=sk-your-deepseek-key
# SMART_LLM__BASE_URL=https://api.deepseek.com/v1
# SMART_LLM__MODEL_NAME=deepseek-chat

# ============================================================
# 使用本地 Ollama 示例
# ============================================================
# CHEAP_LLM__API_KEY=ollama
# CHEAP_LLM__BASE_URL=http://127.0.0.1:11434/v1
# CHEAP_LLM__MODEL_NAME=qwen2.5:7b
#
# SMART_LLM__API_KEY=ollama
# SMART_LLM__BASE_URL=http://127.0.0.1:11434/v1
# SMART_LLM__MODEL_NAME=qwen2.5:14b
#
# ⚠️ Docker 用户注意:
# docker-compose.yml 使用 network_mode: host，容器直接共享宿主机网络，
# .env 中写 127.0.0.1 或 localhost 即可，无需任何修改。

# ============================================================
# 使用智谱 AI 示例
# ============================================================
# CHEAP_LLM__API_KEY=your-zhipu-key
# CHEAP_LLM__BASE_URL=https://open.bigmodel.cn/api/paas/v4
# CHEAP_LLM__MODEL_NAME=glm-4-flash
#
# SMART_LLM__API_KEY=your-zhipu-key
# SMART_LLM__BASE_URL=https://open.bigmodel.cn/api/paas/v4
# SMART_LLM__MODEL_NAME=glm-4

# ============================================================
# 通知配置 (可选)
# ============================================================
# 是否启用通知（也需要在 configs/config.json 中启用）
# ENABLE_NOTIFICATIONS=true

# --- 邮件通知 (SMTP) ---
# 支持 Gmail, QQ邮箱, 163邮箱等
# Gmail 需使用应用专用密码: https://myaccount.google.com/apppasswords
# QQ邮箱: smtp.qq.com, 端口465(SSL) 或 587(TLS)
# 163邮箱: smtp.163.com, 端口465(SSL) 或 25
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=your-email@gmail.com
# SMTP_TO=recipient1@example.com,recipient2@example.com
# SMTP_USE_TLS=true

# --- 企业微信机器人 ---
# 创建方式: 群聊 → 群机器人 → 添加机器人 → 获取 Webhook URL
# WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key

# --- 钉钉机器人 ---
# 创建方式: 群设置 → 智能群助手 → 添加机器人 → 自定义 → 获取 Webhook URL
# 如果启用了签名验证，需同时填写 SECRET
# DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=your-token
# DINGTALK_SECRET=SEC-your-secret

# --- Telegram Bot ---
# 创建 Bot: @BotFather → /newbot → 获取 Token
# 获取 Chat ID: 向 Bot 发消息后访问 https://api.telegram.org/bot<TOKEN>/getUpdates
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# TELEGRAM_CHAT_ID=your-chat-id

# --- Slack ---
# 创建 Incoming Webhook: https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_TEAM/YOUR_CHANNEL/YOUR_TOKEN

# --- 通用 Webhook ---
# 发送 JSON: {"subject": "...", "body": "...", "timestamp": "..."}
# GENERIC_WEBHOOK_URL=https://your-server.com/webhook

# ============================================================
# MinerU PDF 解析 API (可选 - 替代 PyMuPDF 本地解析)
# ============================================================
# MinerU 提供云端 PDF 解析服务，解析质量更高，无需本地资源
# 申请地址: https://mineru.net/apiManage/apiKey
# 注意: Token 有效期为 3 个月，过期后需重新申请
# 每日解析额度: 2000 页（最高优先级），超出后优先级降低
# MINERU_API_KEY=your-mineru-api-token-here

# MinerU 模型版本: pipeline (默认, 快速) 或 vlm (更精确)
# MINERU_MODEL_VERSION=pipeline

# ============================================================
# 高级配置 (可选 - 通常在 configs/config.json 中配置)
# ============================================================

# 重试配置
# RETRY_MAX_ATTEMPTS=3
# RETRY_MIN_WAIT=2
# RETRY_MAX_WAIT=30

# 日志配置
# LOG_KEEP_DAYS=30
# LOG_ROTATION_TYPE=time

# 并发配置
# ENABLE_CONCURRENCY=false
# CONCURRENCY_WORKERS=3

# 报告配置
# ENABLE_HTML_REPORT=false

# 通知 Top-N
# NOTIFICATION_TOP_N=5
